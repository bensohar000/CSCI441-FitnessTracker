{
  "name": "workout-tracker-mini",
  "version": "2.0.0",
  "private": true,
  "description": "A minimal full-stack workout tracker for demos and onboarding.",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10 <11"
  },
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production pnpm -C server start",
    "build": "pnpm -C client build",
    "db:import": "sh database/import.sh",
    "db:generate": "pnpm -C server db:generate",
    "db:migrate": "pnpm -C server db:migrate",
    "db:studio": "pnpm -C server db:studio",
    "db:seed": "pnpm -C server db:seed",
    "dev:client": "pnpm -C client dev",
    "dev:server": "pnpm -C server dev",
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:fresh": "pnpm run dev:clean && pnpm run dev",
    "dev": "npm-run-all --parallel --print-label dev:client dev:server",
    "install:env": "test -f server/.env || cp server/.env.example server/.env",
    "postinstall": "pnpm run install:env",
    "lint:client": "pnpm -C client lint",
    "lint:server": "pnpm -C server lint",
    "lint": "npm-run-all --parallel lint:*",
    "test:client": "pnpm -C client test",
    "test:server": "pnpm -C server test",
    "test": "npm-run-all --parallel --print-label test:client test:server",
    "test:watch:client": "pnpm -C client test:watch",
    "test:watch:server": "pnpm -C server test:watch",
    "test:watch": "npm-run-all --parallel --print-label test:watch:client test:watch:server",
    "test:coverage:client": "pnpm -C client test:coverage",
    "test:coverage:server": "pnpm -C server test:coverage",
    "test:coverage": "npm-run-all --parallel --print-label test:coverage:client test:coverage:server",
    "test:changed": "node scripts/test-changed.mjs",
    "psql": ". server/.env && psql $DATABASE_URL",
    "tsc:client": "pnpm -C client exec tsc --project .",
    "tsc:server": "pnpm -C server exec tsc --project .",
    "tsc": "npm-run-all --continue-on-error tsc:*",
    "prepare": "husky",
    "deploy": "git push origin main:pub"
  },
  "devDependencies": {
    "@learningfuze/lfz-config": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "markuplint": "^3.15.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "es5-ext",
      "esbuild",
      "msw"
    ]
  }
}
