# This app only defines VITE_API_BASE_URL (see client/src/lib/api-base-url.ts).
# Production (Vercel): set in the project Environment UI — values are baked in at build time.
# Optional: absolute API origin when the SPA is not served from the same host as the API
# (e.g. Vercel frontend + Render API). Use https://<your-api>.onrender.com — no trailing slash.
# Leave empty for local dev (Vite proxies /api to the server).
VITE_API_BASE_URL=
