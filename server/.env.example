# Validated keys: server/config/env.ts — copy/paste blocks for Neon + Render: docs/deployment.md
# NODE_ENV defaults to development when unset (use production on Render).
PORT=8080
# Comma-separated allowed browser origins (Vercel production URL, optional preview URLs).
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_WRITE_MAX=60
DATABASE_URL=postgres://dev:dev@localhost/changeMe
# Postgres TLS: auto (default) disables SSL for localhost and enables it for remote hosts (e.g. Neon).
# On Render + Neon, set DATABASE_SSL=true explicitly if you prefer.
DATABASE_SSL=auto
TOKEN_SECRET=changeMe

# --- Optional: demo email/password + guest (disable in prod when OIDC is primary)
AUTH_DEMO_ENABLED=true

# --- OIDC / Auth0 (Path A) — see docs/proposals/auth0-oidc-path-a-build-proposal.md
AUTH_OIDC_ENABLED=false
# AUTH_OIDC_ISSUER=https://YOUR_TENANT.auth0.com/
# AUTH_OIDC_CLIENT_ID=
# AUTH_OIDC_CLIENT_SECRET=
# Use Vite origin in local dev so the OIDC state cookie is sent on callback:
# AUTH_OIDC_REDIRECT_URI=http://localhost:5173/api/auth/oidc/callback
# Split deploy (Vercel + Render): set to SPA origin; enables #oidc_token= fragment handoff
# AUTH_FRONTEND_ORIGIN=https://YOUR_APP.vercel.app
# AUTH_POST_LOGIN_PATH=/
# AUTH_OIDC_LOGIN_STATE_TTL_SECONDS=600
# SESSION_TTL_SECONDS=604800
# Local: lax. Production split deploy: none (requires AUTH_FRONTEND_ORIGIN)
# SESSION_COOKIE_SAME_SITE=lax
# Min 16 chars when AUTH_OIDC_ENABLED=true (else TOKEN_SECRET must be ≥16)
# SESSION_SECRET=
