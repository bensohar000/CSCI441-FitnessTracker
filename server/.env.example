# Validated keys: server/config/env.ts — copy/paste blocks for Neon + Render: docs/deployment.md
# NODE_ENV defaults to development when unset (use production on Render).
PORT=8080
# Comma-separated allowed browser origins (Vercel production URL, optional preview URLs).
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_WRITE_MAX=60
DATABASE_URL=postgres://dev:dev@localhost/changeMe
# Postgres TLS: auto (default) disables SSL for localhost and enables it for remote hosts (e.g. Neon).
# On Render + Neon, set DATABASE_SSL=true explicitly if you prefer.
DATABASE_SSL=auto
TOKEN_SECRET=changeMe
