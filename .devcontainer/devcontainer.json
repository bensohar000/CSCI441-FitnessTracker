{
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "image": "learningfuze/lfz-code",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    }
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${containerWorkspaceFolderBasename}-home_dev,target=/home/dev,type=volume",
    "source=${containerWorkspaceFolderBasename}-postgres_data,target=/var/lib/postgresql,type=volume",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/dev/.ssh,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": ["learningfuze.lfz-pack"]
    }
  },
  "postCreateCommand": "corepack enable && pnpm install --frozen-lockfile; sudo chown -R dev:dev ~/.ssh && chmod 700 ~/.ssh && chmod 600 ~/.ssh/* && chmod 644 ~/.ssh/*.pub",
  "otherPortsAttributes": {
    "onAutoForward": "silent"
  },
  "runArgs": ["--sysctl", "net.ipv6.conf.all.disable_ipv6=1"]
}
